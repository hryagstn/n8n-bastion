# =============================================================
# n8n-bastion Environment Configuration
# =============================================================
# Copy this file to /opt/n8n-bastion/bastion.env
# Fill in your actual values — never commit the real file to Git
#
# Generate a secure webhook secret:
#   openssl rand -hex 32
# =============================================================

# -------------------------------------------------------------
# Laravel Project
# -------------------------------------------------------------
# Absolute path to the Laravel project being monitored
LARAVEL_PATH=/path/to/your/laravel-project

# -------------------------------------------------------------
# n8n Webhook URLs
# -------------------------------------------------------------
# Copy the Production URL from each Webhook node after publishing
# Format: http://127.0.0.1:5678/webhook/<path>
WEBHOOK_SENTINEL=http://127.0.0.1:5678/webhook/sentinel
WEBHOOK_APACHE=http://127.0.0.1:5678/webhook/apache
WEBHOOK_RESOURCE=http://127.0.0.1:5678/webhook/resource
WEBHOOK_UPTIME=http://127.0.0.1:5678/webhook/uptime

# -------------------------------------------------------------
# Webhook Authentication
# -------------------------------------------------------------
# Shared secret between bash scripts and n8n webhook nodes
# Must match the value set in n8n Header Auth credential (X-Bastion-Secret)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_WITH_YOUR_32_CHARACTER_SECRET

# -------------------------------------------------------------
# Application
# -------------------------------------------------------------
# Public URL of the application being monitored (for uptime check)
APP_URL=https://your-domain.com

# -------------------------------------------------------------
# Alert Thresholds (percentage)
# -------------------------------------------------------------
DISK_THRESHOLD=85
RAM_THRESHOLD=90

# -------------------------------------------------------------
# n8n UI Credentials
# -------------------------------------------------------------
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
